                modal = document.createElement('div');
                modal.id = 'hostSelectModal';
                modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9997; display: flex; align-items: center; justify-content: center;';
