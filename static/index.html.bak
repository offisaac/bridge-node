                modal.id = 'systemInfoModal';
                modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9998; display: flex; align-items: center; justify-content: center;';
                document.body.appendChild(modal);
            }
            modal.innerHTML = `<div style="background: var(--bg-secondary); border-radius: 12px; max-width: 450px; max-height: 90vh; overflow-y: auto; padding: 20px; border: 1px solid var(--border);">${html}</div>`;
            modal.style.display = 'flex';
        }

        function showClusterPlugins(host) {
            const plugins = clusterPlugins[host];
            if (!plugins) {
                showToast('No plugin info for ' + host);
                return;
            }

            let html = `<div style="padding: 10px;">
                <h3 style="margin: 0 0 10px 0; color: var(--accent);">📦 ${host} 插件生态</h3>`;

            plugins.forEach(p => {
                html += `<div style="background: var(--bg-tertiary); padding: 10px; margin-bottom: 8px; border-radius: 6px; border: 1px solid var(--border);">
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                        <span style="font-size: 1.2rem;">${p.icon}</span>
                        <span style="font-weight: bold; color: var(--text-primary);">${p.name}</span>
                        <span style="color: var(--text-muted); font-size: 0.8rem;">${p.desc}</span>
                    </div>
                    <div style="background: var(--bg-primary); padding: 6px 10px; border-radius: 4px; font-family: monospace; font-size: 0.75rem; color: var(--success); margin-bottom: 6px;">
                        $ ${p.usage}
                    </div>
                    <a href="${p.docs}" target="_blank" style="color: var(--accent); font-size: 0.75rem;">📖 查看文档</a>
                </div>`;
            });

            html += `<button class="btn btn-secondary" onclick="document.getElementById('pluginModal').style.display='none'" style="margin-top: 10px; width: 100%;">关闭</button></div>`;

            // Create or show modal
            let modal = document.getElementById('pluginModal');
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'pluginModal';
                modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 10000; display: flex; align-items: center; justify-content: center;';
                document.body.appendChild(modal);
            }
            modal.innerHTML = `<div style="background: var(--bg-secondary); border-radius: 12px; max-width: 500px; max-height: 80vh; overflow-y: auto; padding: 20px; border: 1px solid var(--border);">${html}</div>`;
            modal.style.display = 'flex';
        }

        function showClusterEcosystem() {
            let html = `<div style="padding: 10px;">
                <h3 style="margin: 0 0 15px 0; color: var(--accent);">🖥️ 集群生态环境总览</h3>`;

            Object.keys(clusterPlugins).forEach(host => {
                const plugins = clusterPlugins[host];
                html += `<div style="margin-bottom: 15px;">
                    <div style="font-weight: bold; color: var(--text-primary); margin-bottom: 8px; display: flex; align-items: center; gap: 8px;">
                        <span style="color: var(--success);">●</span> ${host}
                        <span style="color: var(--text-muted); font-weight: normal; font-size: 0.8rem;">(${plugins.length} 个工具)</span>
                    </div>
                    <div style="display: flex; flex-wrap: wrap; gap: 6px; padding-left: 20px;">`;
                plugins.forEach(p => {
                    html += `<span style="background: var(--bg-tertiary); padding: 4px 10px; border-radius: 12px; font-size: 0.75rem; cursor: pointer; border: 1px solid var(--border);" ondblclick="showClusterPlugins('${host}'); document.getElementById('ecosystemModal').style.display='none';" title="双击查看详情">${p.icon} ${p.name}</span>`;
                });
                html += `</div></div>`;
            });

            html += `<div style="margin-top: 15px; padding: 10px; background: var(--bg-tertiary); border-radius: 6px; font-size: 0.75rem; color: var(--text-muted);">
                💡 提示：双击某个工具可以查看详细使用说明和文档链接
            </div>
            <button class="btn btn-secondary" onclick="document.getElementById('ecosystemModal').style.display='none'" style="margin-top: 10px; width: 100%;">关闭</button></div>`;

            let modal = document.getElementById('ecosystemModal');
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'ecosystemModal';
                modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; display: flex; align-items: center; justify-content: center;';
                document.body.appendChild(modal);
            }
            modal.innerHTML = `<div style="background: var(--bg-secondary); border-radius: 12px; max-width: 600px; max-height: 80vh; overflow-y: auto; padding: 20px; border: 1px solid var(--border);">${html}</div>`;
            modal.style.display = 'flex';
        }

        // Cluster SSH Functions
        function showSSHPanel() {
            const terminal = document.getElementById('sshTerminal');
            if (terminal) {
                terminal.style.display = 'block';
            }
        }

        function connectCluster(host) {
            const hostInput = document.getElementById('sshHost');
            if (hostInput) {
                hostInput.value = host;
            }
            showSSHPanel();
        }

        async function runSSH() {
            const hostInput = document.getElementById('sshHost');
            const cmdInput = document.getElementById('sshCmd');
            const outputEl = document.getElementById('sshOutput');

            if (!hostInput || !cmdInput) return;

            const host = hostInput.value;
            const command = cmdInput.value;

            if (!command.trim()) {
                showToast('Please enter a command');
                return;
            }

            if (outputEl) {
                outputEl.textContent = 'Executing...';
            }

            try {
                const res = await fetch('/api/ssh/exec', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ host, command })
                });
                const data = await res.json();

                if (data.success) {
                    if (outputEl) {
                        outputEl.textContent = data.output || data.error || 'Command executed (no output)';
                    }
                    log(`SSH: ${host}: ${command}`, 'ssh');
                } else {
                    if (outputEl) {
                        outputEl.textContent = `Error: ${data.error}`;
                    }
                    log(`SSH Error: ${data.error}`, 'error');
                }
            } catch (err) {
                if (outputEl) {
                    outputEl.textContent = `Error: ${err.message}`;
                }
            }
        }

        // Cluster Quick Commands
        async function runClusterCmd(cmd) {
            const host = document.getElementById('clusterCmdHost').value;
            const outputEl = document.getElementById('clusterCmdOutput');
            if (outputEl) outputEl.textContent = '执行中...';

            try {
                const res = await fetch('/api/ssh/exec', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ host, command: cmd })
                });
                const data = await res.json();

                if (outputEl) {
                    outputEl.textContent = data.success ? (data.output || '无输出') : `错误: ${data.error}`;
                }
            } catch (err) {
                if (outputEl) outputEl.textContent = `错误: ${err.message}`;
            }
        }

        async function runClusterCustomCmd() {
            const cmd = document.getElementById('clusterCustomCmd').value.trim();
            if (!cmd) {
                showToast('请输入命令');
                return;
            }
            runClusterCmd(cmd);
        }

        async function browseClusterHome() {
            const host = document.getElementById('clusterFileHost').value;
            const path = document.getElementById('clusterBrowsePath').value || '~';
            const listEl = document.getElementById('clusterFileList');

            listEl.innerHTML = '<div style="text-align: center; padding: 20px; color: var(--accent);">加载中...</div>';

            try {
                const command = `ls -la ${path} 2>/dev/null | head -50`;
                const res = await fetch('/api/ssh/exec', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ host, command })
                });
                const data = await res.json();

                if (data.success && data.output) {
                    const lines = data.output.trim().split('\n');
                    let html = '';

                    lines.forEach(line => {
                        const parts = line.split(/\s+/);
                        if (parts.length < 9) return;

                        const perms = parts[0];
                        const isDir = perms.startsWith('d');
                        const name = parts.slice(8).join(' ');

                        if (name === '.' || name === '..') return;

                        const icon = isDir ? '📁' : '📄';
                        const color = isDir ? 'var(--accent)' : 'var(--text-secondary)';
                        const newPath = isDir ? (path === '~' ? '~/' + name : path + '/' + name) : path;

                        html += `<div style="padding: 4px 8px; cursor: pointer; display: flex; align-items: center; gap: 8px; border-radius: 4px;" onmouseover="this.style.background='var(--bg-tertiary)'" onmouseout="this.style.background='transparent'" onclick="document.getElementById('clusterBrowsePath').value='${newPath}'; browseClusterHome();" title="${line}">
                            <span style="color: ${color};">${icon}</span>
                            <span style="flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${name}</span>
                        </div>`;
                    });

                    if (!html) {
                        html = '<div style="text-align: center; padding: 20px; color: var(--text-muted);">目录为空</div>';
                    }

                    // Add parent directory option
                    if (path !== '~' && path !== '/') {
                        const parentPath = path.includes('/') ? path.replace(/\/[^/]+$/, '') || '~' : '~';
                        html = `<div style="padding: 4px 8px; cursor: pointer; display: flex; align-items: center; gap: 8px; border-radius: 4px; color: var(--accent);" onclick="document.getElementById('clusterBrowsePath').value='${parentPath}'; browseClusterHome();">
                            <span>📂 ..</span>
                        </div>` + html;
                    }

                    listEl.innerHTML = html;
                } else {
                    listEl.innerHTML = `<div style="text-align: center; padding: 20px; color: var(--error);">错误: ${data.error || '无法连接'}</div>`;
                }
            } catch (err) {
                listEl.innerHTML = `<div style="text-align: center; padding: 20px; color: var(--error);">错误: ${err.message}</div>`;
            }
        }

        async function searchFiles() {
            const query = document.getElementById('fileSearchQuery').value.trim();
            if (!query) {
                showToast('Please enter a search query');
                return;
            }

            const listEl = document.getElementById('remoteFileList');
            listEl.innerHTML = '<div style="padding: 20px; text-align: center; color: var(--accent);">Searching...</div>';

            try {
                const res = await apiCall(`/api/remote/search?path=${encodeURIComponent(currentRemotePath)}&query=${encodeURIComponent(query)}`);
                const data = await res.json();

                listEl.innerHTML = '';

                const header = document.createElement('div');
                header.style.cssText = 'display: flex; padding: 8px 12px; background: var(--bg-tertiary); font-weight: 600; font-size: 0.85rem; border-bottom: 1px solid var(--border);';
                header.innerHTML = `<div style="flex: 1;">Search Results: ${data.results.length} matches for "${query}"</div>`;
                listEl.appendChild(header);

                data.results.slice(0, 50).forEach(item => {
                    const itemEl = document.createElement('div');
                    itemEl.style.cssText = 'display: flex; padding: 8px 12px; cursor: pointer; border-bottom: 1px solid var(--border);';
                    itemEl.onmouseover = "this.style.background='var(--bg-tertiary)'";
                    itemEl.onmouseout = "this.style.background='transparent'";

                    const icon = item.is_dir ? '📁' : getFileIcon(item.name);
                    const sizeText = item.is_dir ? '--' : formatSize(item.size);

                    if (item.is_dir) {
                        itemEl.onclick = () => loadRemoteFiles(item.path);
                    } else {
                        itemEl.onclick = () => previewRemoteFile(item.path);
                    }

                    itemEl.innerHTML = `
                        <div style="flex: 1; display: flex; align-items: center; gap: 8px;">
                            <span>${icon}</span>
                            <span>${item.name}</span>
                        </div>
                        <div style="width: 100px; color: var(--text-secondary); font-size: 0.85rem;">${sizeText}</div>
                    `;
                    listEl.appendChild(itemEl);
                });

                if (data.results.length === 0) {
                    listEl.innerHTML = '<div style="padding: 20px; text-align: center; color: var(--text-secondary);">No results found</div>';
                }
            } catch (err) {
                listEl.innerHTML = `<div style="color: var(--error); padding: 20px;">Error: ${err.message}</div>`;
            }
        }

        async function deleteRemoteItem(path, name) {
            if (!confirm(`Are you sure you want to delete "${name}"?`)) {
                return;
            }

            try {
                const res = await apiCall('/api/remote/delete', {
                    method: 'POST',
                    body: JSON.stringify({ path: path })
                });
                const data = await res.json();
                if (data.success) {
                    log(`Deleted: ${name}`, 'success');
                    loadRemoteFiles(currentRemotePath);
                }
            } catch (err) {
                log(`Delete failed: ${err.message}`, 'error');
            }
        }

        async function renameRemoteItem(path, oldName) {
            const newName = prompt('Enter new name:', oldName);
            if (!newName || newName === oldName) return;

            try {
                const res = await apiCall('/api/remote/rename', {
                    method: 'POST',
                    body: JSON.stringify({ old_path: path, new_name: newName })
                });
                const data = await res.json();
                if (data.success) {
                    log(`Renamed: ${oldName} -> ${newName}`, 'success');
                    loadRemoteFiles(currentRemotePath);
                }
            } catch (err) {
                log(`Rename failed: ${err.message}`, 'error');
            }
        }

        async function createNewFolder() {
            const folderName = prompt('Enter folder name:');
            if (!folderName) return;

            const newPath = currentRemotePath === '/' ? '/' + folderName : currentRemotePath + '/' + folderName;

            try {
                const res = await apiCall('/api/remote/mkdir', {
                    method: 'POST',
                    body: JSON.stringify({ path: newPath })
                });
                const data = await res.json();
                if (data.success) {
                    log(`Created folder: ${folderName}`, 'success');
                    loadRemoteFiles(currentRemotePath);
                }
            } catch (err) {
                log(`Create folder failed: ${err.message}`, 'error');
            }
        }

        async function previewRemoteFile(path) {
            const previewEl = document.getElementById('filePreviewContent');
            const modal = document.getElementById('filePreviewModal');
            document.getElementById('previewTitle').innerHTML = '📄 File Preview';
            previewEl.innerHTML = '<div style="text-align: center; padding: 40px;"><div class="spinner" style="margin: 0 auto;"></div><p style="margin-top: 10px; color: var(--text-secondary);">Loading preview...</p></div>';
            document.getElementById('filePreviewPath').textContent = path;
            modal.classList.remove('hidden');
            modal.style.display = 'flex';

            try {
                const res = await fetch(`/api/remote/read?path=${encodeURIComponent(path)}`);
                const data = await res.json();

                const ext = path.split('.').pop().toLowerCase();
                const imageExts = ['png', 'jpg', 'jpeg', 'gif', 'webp', 'bmp', 'svg'];

                if (imageExts.includes(ext)) {
                    const img = document.createElement('img');
                    img.src = `/api/remote/read?path=${encodeURIComponent(path)}`;
                    img.style.maxWidth = '100%';
                    img.style.maxHeight = '60vh';
                    img.style.objectFit = 'contain';
                    img.style.borderRadius = '8px';
                    img.style.boxShadow = 'var(--shadow)';
                    img.onload = () => img.style.opacity = '1';
                    img.style.opacity = '0';
                    img.style.transition = 'opacity 0.3s';

                    previewEl.innerHTML = '';
                    previewEl.appendChild(img);
                } else if (ext === 'pdf') {
                    previewEl.innerHTML = `<iframe src="/api/remote/read?path=${encodeURIComponent(path)}" style="width: 100%; height: 60vh; border: none; border-radius: 8px;"></iframe>`;
                } else {
                    const content = data.content || 'Unable to read file';
                    previewEl.innerHTML = `<pre style="white-space: pre-wrap; font-size: 0.85rem; max-height: 60vh; overflow-y: auto; background: var(--bg-primary); padding: 16px; border-radius: 8px;">${escapeHtml(content.substring(0, 50000))}</pre>`;
                }
            } catch (err) {
                previewEl.innerHTML = `<div style="color: var(--error); text-align: center; padding: 40px;">Error: ${err.message}</div>`;
            }
        }

        // Quick Commands
        async function quickCommand(cmd) {
            const outputEl = document.getElementById('quickCommandOutput');
            outputEl.style.display = 'block';
            outputEl.textContent = `Running: ${cmd}\n\nExecuting...`;

            addActivity('⚡', `Running: ${cmd}`);

            try {
                const res = await apiCall('/api/command', {
                    method: 'POST',
                    body: JSON.stringify({ command: cmd, params: {} })
                });
                const data = await res.json();

                if (data.output) {
                    outputEl.textContent = `$ ${cmd}\n\n${data.output}`;
                    addActivity('✅', `Completed: ${cmd}`);
                } else if (data.error) {
                    outputEl.textContent = `$ ${cmd}\n\nError: ${data.error}`;
                    addActivity('❌', `Failed: ${cmd}`);
                } else {
                    outputEl.textContent = `$ ${cmd}\n\n${JSON.stringify(data, null, 2)}`;
                }
            } catch (err) {
                outputEl.textContent = `$ ${cmd}\n\nError: ${err.message}`;
                addActivity('❌', `Error: ${cmd}`);
            }
        }

        // Activity Log Functions
        function addActivity(icon, message) {
            const timestamp = new Date().toLocaleTimeString();
            activityLog.unshift({ icon, message, timestamp });
            if (activityLog.length > 50) activityLog.pop();
            renderActivityLog();
        }

        function renderActivityLog() {
            const el = document.getElementById('activityLog');
            if (activityLog.length === 0) {
                el.innerHTML = '<div style="color: var(--text-muted); text-align: center; padding: 20px;">Activity will appear here...</div>';
                return;
            }
            el.innerHTML = activityLog.map(a => `
                <div style="padding: 6px 8px; border-bottom: 1px solid var(--border); display: flex; gap: 8px; align-items: flex-start;">
                    <span style="flex-shrink: 0;">${a.icon}</span>
                    <span style="flex: 1; word-break: break-all;">${escapeHtml(a.message)}</span>
                    <span style="flex-shrink: 0; color: var(--text-muted); font-size: 0.7rem;">${a.timestamp}</span>
                </div>
            `).join('');
        }

        function clearActivityLog() {
            activityLog = [];
            renderActivityLog();
            addActivity('🗑️', 'Activity log cleared');
        }

        function closeFilePreview() {
            const modal = document.getElementById('filePreviewModal');
            modal.classList.add('hidden');
            modal.style.display = 'none';
        }

        // Show changelog in file preview modal
        function showChangelog() {
            const modal = document.getElementById('filePreviewModal');
            document.getElementById('previewTitle').innerHTML = '📋 Changelog';
            document.getElementById('filePreviewPath').textContent = 'BridgeNode Update History';
            const contentEl = document.getElementById('filePreviewContent');

            const changelog = `
<div style="padding: 10px;">

<div style="margin-bottom: 20px; padding: 12px; background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(99, 102, 241, 0.1) 100%); border-radius: 8px; border-left: 3px solid var(--accent);">
<div style="color: var(--accent); font-weight: 600; margin-bottom: 8px;">Latest Updates</div>
<div style="color: var(--text-secondary); font-size: 0.8rem;">2026-02-14</div>
<ul style="margin: 8px 0 0 16px; color: var(--text-secondary); font-size: 0.85rem; line-height: 1.8;">
<li>Claude Input Module - integrity verification</li>
<li>Output statistics - char/line/word counts</li>
<li>JSON export and deduplication</li>
<li>MD5 checksum support</li>
</ul>
</div>

<div style="margin-bottom: 20px; padding: 12px; background: var(--bg-tertiary); border-radius: 8px; border-left: 3px solid #6366f1;">
<div style="color: var(--text-primary); font-weight: 600; margin-bottom: 8px;">UI Enhancements</div>
<ul style="margin: 8px 0 0 16px; color: var(--text-secondary); font-size: 0.85rem; line-height: 1.8;">
<li>Black-purple gradient theme</li>
<li>Gradient scrollbars and toasts</li>
<li>Breathing light animations</li>
</ul>
</div>

<div style="padding: 12px; background: var(--bg-tertiary); border-radius: 8px; border-left: 3px solid #4f46e5;">
<div style="color: var(--text-primary); font-weight: 600; margin-bottom: 8px;">Core Features</div>
<ul style="margin: 8px 0 0 16px; color: var(--text-secondary); font-size: 0.85rem; line-height: 1.8;">
<li>SSH tunnel web interface</li>
<li>Real-time log monitoring</li>
<li>File upload/download</li>
<li>Push API for Claude</li>
</ul>
</div>

</div>`;

            contentEl.innerHTML = changelog;
            modal.classList.remove('hidden');
            modal.style.display = 'flex';
        }

        async function calculateDirSize(path) {
            try {
                const res = await apiCall(`/api/remote/size?path=${encodeURIComponent(path)}`);
                const data = await res.json();
                showToast(`Size: ${data.size_formatted}`);
            } catch (err) {
                showToast('Error: ' + err.message);
            }
        }

        // Claude Output Monitor
        function setClaudePath() {
            const path = document.getElementById('claudeOutputPath').value;
            if (path) {
                localStorage.setItem('claude_output_path', path);
                log(`Claude output path set to: ${path}`, 'success');
                startClaudeMonitor();
            }
        }

        async function startClaudeMonitor() {
            let path = document.getElementById('claudeOutputPath').value;
            if (!path) {
                path = localStorage.getItem('claude_output_path') || '~/claude-output';
                document.getElementById('claudeOutputPath').value = path;
            }

            if (claudeMonitorInterval) {
                clearInterval(claudeMonitorInterval);
            }

            const consoleEl = document.getElementById('claudeOutputConsole');
            consoleEl.innerHTML = '<div style="color: var(--accent);">Monitoring: ' + path + '</div>';

            // Initial load
            await checkClaudeOutput(path);

            // Poll every 2 seconds
            claudeMonitorInterval = setInterval(() => checkClaudeOutput(path), 2000);
            log('Claude monitor started', 'success');
        }

        async function checkClaudeOutput(path) {
            try {
                const res = await apiCall(`/api/remote/list?path=${encodeURIComponent(path)}`);
                const data = await res.json();

                const consoleEl = document.getElementById('claudeOutputConsole');
                let hasNew = false;

                data.items.forEach(item => {
                    if (!item.is_dir) {
                        const key = item.path + '_' + item.modified;
                        if (!lastClaudeFiles[key]) {
                            lastClaudeFiles[key] = true;
                            hasNew = true;

                            // Read new file content
                            readClaudeFile(item.path);
                        }
                    }
                });

                if (data.items.length === 0) {
                    consoleEl.innerHTML = '<div style="color: var(--text-secondary);">No files in directory</div>';
                }
            } catch (err) {
                // Ignore errors silently
            }
        }

        async function readClaudeFile(filepath) {
            try {
                // Use a simple fetch to get file content (need to add endpoint)
                const res = await fetch(`/api/remote/read?path=${encodeURIComponent(filepath)}`, {
                    headers: { 'Content-Type': 'application/json' }
                });
                if (res.ok) {
                    const content = await res.text();
                    await addClaudeOutput(content, filepath.split('/').pop());
                }
            } catch (err) {
                console.error('Read file error:', err);
            }
        }

        // Claude Input Functions
        function updateInputStats() {
            const content = document.getElementById('claudeInputArea').value;
            const charCount = content.length;
            const lineCount = content.split('\n').length;
            const wordCount = content.trim() ? content.trim().split(/\s+/).length : 0;

            document.getElementById('inputCharCount').textContent = charCount + ' chars';
            document.getElementById('inputLineCount').textContent = lineCount + ' lines';
            document.getElementById('inputWordCount').textContent = wordCount + ' words';
        }

        async function submitClaudeInput() {
            const content = document.getElementById('claudeInputArea').value.trim();
            if (!content) {
                showToast('Please enter some content!', 'warning');
                return;
            }

            const verifyIntegrity = document.getElementById('verifyIntegrity').checked;

            const btn = document.getElementById('submitInputBtn');
            btn.disabled = true;
            btn.textContent = '⏳ Sending...';

            try {
                const response = await fetch('/api/claude/input', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        content: content,
                        expected_length: verifyIntegrity ? content.length : 0
                    })
                });

                const result = await response.json();

                const statusEl = document.getElementById('inputStatus');
                statusEl.style.display = 'block';

                if (result.success) {
                    let statusHtml = `<div style="color: var(--success);">✅ Input submitted successfully!</div>`;
                    statusHtml += `<div style="margin-top: 6px; color: var(--text-secondary); font-size: 0.75rem;">`;
                    statusHtml += `📊 Length: ${result.content_length} chars | Lines: ${result.line_count} | Words: ${result.word_count}<br>`;
                    statusHtml += `🔐 MD5: <code style="background: var(--bg-primary); padding: 2px 4px; border-radius: 3px;">${result.md5}</code><br>`;
                    statusHtml += `📋 SHA256: <code style="background: var(--bg-primary); padding: 2px 4px; border-radius: 3px;">${result.sha256}</code>`;

                    if (verifyIntegrity && result.expected_length > 0) {
                        statusHtml += `<br>✅ Length verified: ${result.length_match ? 'Match' : 'Mismatch'}`;
                    }
                    statusHtml += `</div>`;
                    statusEl.innerHTML = statusHtml;

                    showToast('Input submitted to Claude!', 'success');
                } else {
                    statusEl.innerHTML = `<div style="color: var(--error);">❌ Error: ${result.message}</div>`;
                }
            } catch (err) {
                const statusEl = document.getElementById('inputStatus');
                statusEl.style.display = 'block';
                statusEl.innerHTML = `<div style="color: var(--error);">❌ Error: ${err.message}</div>`;
                showToast('Failed to submit input!', 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = '📤 Submit to Claude';
            }
        }

        function clearClaudeInput() {
            document.getElementById('claudeInputArea').value = '';
            updateInputStats();
            document.getElementById('inputStatus').style.display = 'none';
            showToast('Input cleared!', 'info');
        }

        // Compute MD5 checksum
        async function computeChecksum(text) {
            const encoder = new TextEncoder();
            const data = encoder.encode(text);
            const hashBuffer = await crypto.subtle.digest('MD5', data).catch(() => null);
            if (!hashBuffer) {
                // Fallback: simple hash
                let hash = 0;
                for (let i = 0; i < text.length; i++) {
                    const char = text.charCodeAt(i);
                    hash = ((hash << 5) - hash) + char;
                    hash = hash & hash;
                }
                return Math.abs(hash).toString(16);
            }
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
        }

        // Add output to display
        async function addClaudeOutput(content, label = 'Manual Input') {
            const checksum = await computeChecksum(content);
            const output = {
                id: Date.now(),
                content: content,
                label: label,
                timestamp: new Date().toLocaleString(),
                checksum: checksum
            };
            claudeOutputs.unshift(output);
            if (claudeOutputs.length > 50) claudeOutputs.pop();
            renderClaudeOutputs();
        }

        // Render all outputs - grid layout (2-3 per row)
        function renderClaudeOutputs() {
            const consoleEl = document.getElementById('claudeOutputConsole');
            document.getElementById('outputCount').textContent = claudeOutputs.length + ' outputs';

            // Save to localStorage
            localStorage.setItem('claudeOutputs', JSON.stringify(claudeOutputs));

            if (claudeOutputs.length === 0) {
                consoleEl.innerHTML = '<div style="color: var(--text-secondary); text-align: center; padding: 20px;">No outputs yet. Click "Manual" to paste Claude\'s response, or "Monitor" to watch a directory.</div>';
                return;
            }

            consoleEl.innerHTML = `<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 12px;">` +
                claudeOutputs.map(output => {
                    const charCount = output.content.length;
                    const lineCount = output.content.split('\n').length;
                    const checksum = output.checksum || '';
                    return `
                    <div style="border: 1px solid var(--border); border-radius: 8px; overflow: hidden; background: var(--bg-secondary);">
                        <div style="background: var(--bg-tertiary); padding: 6px 10px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 4px;">
                            <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                                <span style="color: var(--accent); font-weight: 500; font-size: 0.8rem;">${escapeHtml(output.label)}</span>
                                <span style="font-size: 0.6rem; color: var(--text-muted);">${charCount} chars</span>
                                ${checksum ? `<span style="font-size: 0.6rem; color: var(--accent);" title="MD5">🔐${checksum.substring(0, 6)}</span>` : ''}
                            </div>
                            <div style="display: flex; gap: 4px; align-items: center;">
                                <span style="font-size: 0.6rem; color: var(--text-muted);">${output.timestamp.split(' ')[1] || ''}</span>
                                <button onclick="copySingleOutput(${output.id})" style="background: none; border: 1px solid var(--border); border-radius: 3px; padding: 1px 6px; font-size: 0.6rem; cursor: pointer; color: var(--text-secondary);">📋</button>
                                <button onclick="deleteOutput(${output.id})" style="background: none; border: 1px solid var(--border); border-radius: 3px; padding: 1px 6px; font-size: 0.6rem; cursor: pointer; color: var(--error);">×</button>
                            </div>
                        </div>
                        <pre style="white-space: pre-wrap; font-size: 0.7rem; padding: 8px; margin: 0; max-height: 150px; overflow-y: auto; background: var(--bg-primary);">${escapeHtml(output.content.substring(0, 3000))}</pre>
                    </div>
                `}).join('') + `</div>`;
        }

        // Toggle manual input section
        function toggleManualInput() {
            const section = document.getElementById('manualInputSection');
            const btn = document.getElementById('manualInputBtn');
            if (section.style.display === 'none') {
                section.style.display = 'block';
                btn.textContent = '✏️ Done';
                btn.style.background = 'var(--accent)';
                btn.style.color = 'white';
            } else {
                section.style.display = 'none';
                btn.textContent = '✏️ Manual';
                btn.style.background = '';
                btn.style.color = '';
            }
        }

        // Add manual output
        async function addManualOutput() {
            const input = document.getElementById('manualClaudeInput');
            const content = input.value.trim();
            if (content) {
                await addClaudeOutput(content, 'Manual Input #' + (claudeOutputs.length + 1));
                input.value = '';
                showToast('Output added!', 'success');
            }
        }

        // Clear manual input
        function clearManualOutput() {
            document.getElementById('manualClaudeInput').value = '';
        }

        // Copy single output
        function copySingleOutput(id) {
            const output = claudeOutputs.find(o => o.id === id);
            if (output) {
                navigator.clipboard.writeText(output.content);
                showToast('Copied to clipboard!', 'success');
            }
        }

        // Copy all outputs
        function copyAllOutput() {
            const allText = claudeOutputs.map(o => `=== ${o.label} ===\n${o.content}`).join('\n\n');
            navigator.clipboard.writeText(allText);
            showToast('All outputs copied!', 'success');
        }

        // Delete single output
        function deleteOutput(id) {
            claudeOutputs = claudeOutputs.filter(o => o.id !== id);
            renderClaudeOutputs();
        }

        // Show statistics
        function showStats() {
            if (claudeOutputs.length === 0) {
                showToast('No outputs to analyze!', 'warning');
                return;
            }
            const totalChars = claudeOutputs.reduce((sum, o) => sum + o.content.length, 0);
            const totalLines = claudeOutputs.reduce((sum, o) => sum + o.content.split('\n').length, 0);
            const totalWords = claudeOutputs.reduce((sum, o) => {
                const trimmed = o.content.trim();
                return sum + (trimmed ? trimmed.split(/\s+/).length : 0);
            }, 0);
            const avgLength = Math.round(totalChars / claudeOutputs.length);

            const statsMsg = `📊 Stats:
• Outputs: ${claudeOutputs.length}
• Total Chars: ${totalChars.toLocaleString()}
• Total Lines: ${totalLines.toLocaleString()}
• Total Words: ${totalWords.toLocaleString()}
• Avg Length: ${avgLength} chars`;

            alert(statsMsg);
        }

        // Export to JSON
        function exportOutputsJSON() {
            if (claudeOutputs.length === 0) {
                showToast('No outputs to export!', 'warning');
                return;
            }
            const data = {
                exportTime: new Date().toISOString(),
                totalOutputs: claudeOutputs.length,
                outputs: claudeOutputs
            };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `claude-outputs-${Date.now()}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('Exported to JSON!', 'success');
        }

        // Deduplicate outputs
        function deduplicateOutputs() {
            if (claudeOutputs.length === 0) {
                showToast('No outputs to deduplicate!', 'warning');
                return;
            }
            const originalCount = claudeOutputs.length;
            const seen = new Set();
            claudeOutputs = claudeOutputs.filter(o => {
                const key = o.checksum || o.content.substring(0, 100);
                if (seen.has(key)) return false;
                seen.add(key);
                return true;
            });
            const removed = originalCount - claudeOutputs.length;
            if (removed > 0) {
                renderClaudeOutputs();
                showToast(`Removed ${removed} duplicate(s)!`, 'success');
            } else {
                showToast('No duplicates found!', 'info');
            }
        }

        function showToast(message, type = 'info', duration = 3000) {
            const existing = document.querySelector('.toast');
            if (existing) existing.remove();

            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            toast.innerHTML = `
                <span>${message}</span>
                <button class="toast-close" onclick="this.parentElement.remove()">×</button>
            `;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), duration);
        }

        function confirmAction(message) {
            return new Promise((resolve) => {
                const overlay = document.createElement('div');
                overlay.className = 'modal-overlay';
                overlay.innerHTML = `
                    <div class="modal-content" style="max-width: 400px; padding: 24px;">
                        <p style="margin-bottom: 20px; font-size: 1rem;">${message}</p>
                        <div style="display: flex; gap: 12px; justify-content: flex-end;">
                            <button class="btn btn-secondary" onclick="this.closest('.modal-overlay').remove(); resolve(false);">Cancel</button>
                            <button class="btn btn-primary" onclick="this.closest('.modal-overlay').remove(); resolve(true);">Confirm</button>
                        </div>
                    </div>
                `;
                document.body.appendChild(overlay);
            });
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Favorites management
        function loadFavorites() {
            const favorites = JSON.parse(localStorage.getItem('bridge_favorites') || '[]');
            return favorites;
        }

        function saveFavorite(path) {
            const favorites = loadFavorites();
            if (!favorites.includes(path)) {
                favorites.push(path);
                localStorage.setItem('bridge_favorites', JSON.stringify(favorites));
                showToast('Added to favorites: ' + path);
                renderFavorites();
            }
        }

        function removeFavorite(path) {
            const favorites = loadFavorites().filter(f => f !== path);
            localStorage.setItem('bridge_favorites', JSON.stringify(favorites));
            showToast('Removed from favorites');
            renderFavorites();
        }

        function renderFavorites() {
            const favorites = loadFavorites();
            const container = document.getElementById('favoritesContainer');
            if (!container) return;

            container.innerHTML = '';
            favorites.forEach(path => {
                const div = document.createElement('div');
                div.style.cssText = 'padding: 6px 8px; cursor: pointer; border-radius: 4px; display: flex; align-items: center; gap: 8px; justify-content: space-between;';
                div.innerHTML = `
                    <span onclick="loadRemoteFiles('${path}')" style="display: flex; align-items: center; gap: 8px; flex: 1;">
                        <span>⭐</span> <span style="font-size: 0.8rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${path.split('/').pop() || path}</span>
                    </span>
                    <span onclick="removeFavorite('${path}')" style="color: var(--error); font-size: 0.8rem;">&times;</span>
                `;
                container.appendChild(div);
            });
        }

        function addCurrentToFavorites() {
            if (currentRemotePath) {
                saveFavorite(currentRemotePath);
            }
        }

        // Theme toggle
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            if (newTheme === 'dark') {
                html.removeAttribute('data-theme');
            } else {
                html.setAttribute('data-theme', 'light');
            }
            localStorage.setItem('bridge_theme', newTheme);
            document.querySelector('.theme-toggle-btn').textContent = newTheme === 'light' ? '🌙' : '☀️';
            updateFileListBackground(newTheme);
        }

        function updateFileListBackground(theme) {
            const bg = theme === 'light'
                ? 'linear-gradient(180deg, #ffffff 0%, #f0f5ff 100%)'
                : 'linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%)';
            document.getElementById('localFileList').style.background = bg;
            document.getElementById('remoteFileList').style.background = bg;
        }

        // Load theme
        function loadTheme() {
            const savedTheme = localStorage.getItem('bridge_theme') || 'dark';
            if (savedTheme === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
            document.querySelector('.theme-toggle-btn').textContent = savedTheme === 'light' ? '☀️' : '🌙';
            updateFileListBackground(savedTheme);
        }

        // Data Export
        function exportData() {
            const data = {
                exportTime: new Date().toISOString(),
                stats: {
                    latency: document.getElementById('latency').textContent,
                    connections: document.getElementById('connections').textContent,
                    cpu: document.getElementById('cpuUsage').textContent,
                    memory: document.getElementById('memUsage').textContent,
                    uptime: document.getElementById('uptime').textContent
                },
                logHistory: logHistory,
                commandHistory: commandHistory
            };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `bridge-node-export-${Date.now()}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('Data exported successfully!', 'success');
        }

        // Keyboard shortcuts help
        function showShortcuts() {
            const shortcuts = [
                ['Ctrl+K', 'Focus command input'],
                ['Ctrl+L', 'Refresh logs'],
                ['Ctrl+T', 'Toggle theme'],
                ['Ctrl+S', 'Refresh status'],
                ['Ctrl+/', 'Show this help'],
                ['Escape', 'Close modal'],
                ['↑/↓', 'Command history']
            ];
            const html = shortcuts.map(([key, desc]) => `<div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid rgba(139, 92, 246, 0.1);"><code style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(99, 102, 241, 0.15) 100%); padding: 4px 10px; border-radius: 6px; font-size: 0.85rem; color: #a78bfa; border: 1px solid rgba(139, 92, 246, 0.3);">${key}</code><span style="color: var(--text-secondary); font-size: 0.9rem;">${desc}</span></div>`).join('');
            showToast(`<div style="min-width: 300px;"><div style="font-weight: 600; margin-bottom: 12px; color: var(--accent); font-size: 1rem;">Keyboard Shortcuts</div>${html}</div>`, 'info', 8000);
        }

        // Enter key for logs
        document.getElementById('logPath').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') refreshLogs();
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            // Ignore if typing in input/textarea
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

            // Ctrl/Cmd + K: Quick command
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                document.querySelector('.command-input input')?.focus();
            }
            // Ctrl/Cmd + L: Refresh logs
            if ((e.ctrlKey || e.metaKey) && e.key === 'l') {
                e.preventDefault();
                refreshLogs();
            }
            // Ctrl/Cmd + T: Toggle theme
            if ((e.ctrlKey || e.metaKey) && e.key === 't') {
                e.preventDefault();
                toggleTheme();
            }
            // Ctrl/Cmd + /: Show shortcuts help
            if ((e.ctrlKey || e.metaKey) && e.key === '/') {
                e.preventDefault();
                showToast('⌨️ Shortcuts: Ctrl+K=Command, Ctrl+L=Logs, Ctrl+T=Theme, Ctrl+S=Status');
            }
            // Ctrl/Cmd + S: Refresh status
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                fetchStatus();
            }
            // Escape: Close modals
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal-overlay').forEach(m => m.classList.add('hidden'));
            }
        });

        // Scroll to top
        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        window.addEventListener('scroll', () => {
            document.getElementById('scrollTop').classList.toggle('visible', window.scrollY > 300);
        });

        // Auto-save key inputs
        const autoSaveInputs = ['remotePath', 'logPath', 'claudeOutputPath'];
        autoSaveInputs.forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                const saved = localStorage.getItem(id);
                if (saved) el.value = saved;
                el.addEventListener('change', () => localStorage.setItem(id, el.value));
            }
        });

        // Initialize on page load
        username = 'admin';
        password = 'password';
        loadTheme();

        // Changelog button handler
        document.getElementById('changelogBtn').addEventListener('click', function() {
            showChangelog();
        });
        renderFavorites();
        initDragDrop();

        // Network status monitoring
        window.addEventListener('online', () => {
            showToast('Network restored', 'success');
            connectWebSocket();
        });
        window.addEventListener('offline', () => {
            showToast('Network disconnected', 'warning');
            document.getElementById('connectionStatus').textContent = 'Offline';
        });

        // Storage management
        function clearStorage() {
            if (confirm('Clear all local storage data?')) {
                localStorage.clear();
                showToast('Storage cleared', 'success');
            }
        }

        // Debounced search
        let searchTimeout;
        document.getElementById('fileSearchQuery')?.addEventListener('input', (e) => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                if (e.target.value.length >= 3) {
                    searchFiles();
                }
            }, 500);
        });

        log('BridgeNode ready! ⌨️ Ctrl+/ for shortcuts', 'success');
        connectWebSocket();
        fetchStatus();
        // Load file managers
        loadLocalFiles();
        loadRemoteFiles('/home/pengxiang');
        // Load Claude outputs
        renderClaudeOutputs();
    </script>
</body>
</html>
