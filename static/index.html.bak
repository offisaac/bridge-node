        function showClusterStatus(host, cmd) {
            executeClusterCommand(host, cmd, 'clusterStatusOutput');
        }

        async function executeClusterCommand(host, cmd, outputId) {
            const outputEl = document.getElementById(outputId);
            if (outputEl) outputEl.textContent = '执行中...';

            try {
                const res = await fetch('/api/ssh/exec', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ host, command: cmd })
                });
                const data = await res.json();

                if (outputEl) {
                    outputEl.textContent = data.success ? (data.output || '无输出') : `错误: ${data.error}`;
                }
            } catch (err) {
                if (outputEl) outputEl.textContent = `错误: ${err.message}`;
            }
        }

        function promptClusterHost(action) {
            const hosts = ['isee101', 'isee221', 'isee223', 'isee229'];
            let html = `<div style="padding: 10px;">
                <h3 style="margin: 0 0 15px 0; color: var(--accent);">选择集群节点</h3>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">`;

            hosts.forEach(h => {
                html += `<button class="btn btn-secondary" onclick="document.getElementById('hostSelectModal').style.display='none'; ${action === 'system' ? 'showClusterSystemInfo' : action === 'plugins' ? 'showClusterPlugins' : 'connectCluster'}('${h}')" style="padding: 12px; font-size: 0.85rem;">
                    🖥️ ${h}
                </button>`;
